generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  accounts  Account[]
  documents Document[]
  bookings  Booking[]
  invoices  Invoice[]
  offers    Offer[]
  bankTransactions BankTransaction[]
  autoRules Rule[]
  taxSnapshots TaxSnapshot[]
}

model Account {
  id        String   @id @default(cuid())
  number    String
  name      String
  type      String
  skrType   String
  taxRate   Float
  category  String
  active    Boolean  @default(true)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, skrType])
  @@unique([companyId, number, skrType])
}

model Document {
  id           String    @id @default(cuid())
  fileName      String
  status        String
  accountNumber String?
  category      String?
  grossAmount   Float     @default(0)
  taxAmount     Float     @default(0)
  netAmount     Float     @default(0)
  partner       String?
  documentDate  DateTime?
  dueDate       DateTime?
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking       Booking?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId, status])
}

model Booking {
  id            String   @id @default(cuid())
  documentId     String   @unique
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  debitAccount   String
  creditAccount  String
  amount         Float
  taxAmount      Float
  bookingText    String
  bookingDate    DateTime
  category       String
  status         String
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model Invoice {
  id          String   @id @default(cuid())
  number      String
  customer    String
  amountNet   Float
  amountTax   Float
  amountGross Float
  dueDate     DateTime
  status      String
  sourceOfferId String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, status])
  @@unique([companyId, number])
}

model Offer {
  id          String   @id @default(cuid())
  number      String
  customer    String
  amountNet   Float
  amountTax   Float
  amountGross Float
  validUntil  DateTime
  status      String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, status])
  @@unique([companyId, number])
}

model BankTransaction {
  id          String   @id @default(cuid())
  bookingDate DateTime
  valueDate   DateTime?
  purpose     String
  counterparty String?
  amount      Float
  currency    String   @default("EUR")
  type        String
  status      String
  matchedInvoiceId String?
  matchedDocumentId String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, bookingDate])
}

model Rule {
  id          String   @id @default(cuid())
  name        String
  pattern     String
  accountNumber String?
  category    String?
  confidence  Float    @default(0.9)
  active      Boolean  @default(true)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, active])
}

model TaxSnapshot {
  id            String   @id @default(cuid())
  periodLabel    String
  year           Int
  month          Int
  vatOutput19    Float   @default(0)
  vatInput       Float   @default(0)
  vatLiability   Float   @default(0)
  euerRevenue    Float   @default(0)
  euerExpense    Float   @default(0)
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId, year, month])
  @@unique([companyId, year, month])
}
