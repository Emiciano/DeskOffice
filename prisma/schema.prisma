generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  users     User[]
  accounts  Account[]
  documents Document[]
  bookings  Booking[]
  invoices  Invoice[]
  offers    Offer[]
  bankTransactions BankTransaction[]
  autoRules Rule[]
  taxSnapshots TaxSnapshot[]
  contacts Contact[]
  exports DataExport[]
  settings  CompanySettings?
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("owner")
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sessions     AuthSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([companyId, role])
}

model AuthSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model CompanySettings {
  id                     String   @id @default(cuid())
  companyId              String   @unique
  company                Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName            String   @default("")
  companySuffix          String   @default("")
  legalForm              String   @default("")
  managingDirector       String   @default("")
  street                 String   @default("")
  postalCode             String   @default("")
  city                   String   @default("")
  country                String   @default("Deutschland")
  phone                  String   @default("")
  fax                    String   @default("")
  email                  String   @default("")
  website                String   @default("")
  vatId                  String   @default("")
  taxNumber              String   @default("")
  districtCourt          String   @default("")
  commercialRegisterNo   String   @default("")
  vatMode                String   @default("standard")
  profitMethod           String   @default("euer")
  defaultTaxRate         Float    @default(19)
  accountFrame           String   @default("SKR04")
  priceInputMode         String   @default("brutto")
  bankName               String   @default("")
  accountNumber          String   @default("")
  bankCode               String   @default("")
  iban                   String   @default("")
  bic                    String   @default("")
  logoUrl                String   @default("")
  updatedAt              DateTime @updatedAt
  createdAt              DateTime @default(now())
}

model Account {
  id        String   @id @default(cuid())
  number    String
  name      String
  type      String
  skrType   String
  taxRate   Float
  category  String
  active    Boolean  @default(true)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, skrType])
  @@unique([companyId, number, skrType])
}

model Document {
  id           String    @id @default(cuid())
  fileName      String
  status        String
  accountNumber String?
  category      String?
  grossAmount   Float     @default(0)
  taxAmount     Float     @default(0)
  netAmount     Float     @default(0)
  partner       String?
  documentDate  DateTime?
  dueDate       DateTime?
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking       Booking?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId, status])
}

model Booking {
  id            String   @id @default(cuid())
  documentId     String   @unique
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  debitAccount   String
  creditAccount  String
  amount         Float
  taxAmount      Float
  bookingText    String
  bookingDate    DateTime
  category       String
  status         String
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model Invoice {
  id          String   @id @default(cuid())
  number      String
  customer    String
  amountNet   Float
  amountTax   Float
  amountGross Float
  dueDate     DateTime
  status      String
  sourceOfferId String?
  kind        String   @default("Rechnung")
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items       InvoiceItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, status])
  @@unique([companyId, number])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float
  amountNet   Float
  amountTax   Float
  amountGross Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Offer {
  id          String   @id @default(cuid())
  number      String
  customer    String
  amountNet   Float
  amountTax   Float
  amountGross Float
  validUntil  DateTime
  status      String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, status])
  @@unique([companyId, number])
}

model BankTransaction {
  id          String   @id @default(cuid())
  bookingDate DateTime
  valueDate   DateTime?
  purpose     String
  counterparty String?
  amount      Float
  currency    String   @default("EUR")
  type        String
  status      String
  category    String?
  suggestedAccount String?
  matchedRuleId String?
  matchedInvoiceId String?
  matchedDocumentId String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, bookingDate])
}

model Rule {
  id          String   @id @default(cuid())
  name        String
  pattern     String
  accountNumber String?
  category    String?
  confidence  Float    @default(0.9)
  active      Boolean  @default(true)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, active])
}

model TaxSnapshot {
  id            String   @id @default(cuid())
  periodLabel    String
  year           Int
  month          Int
  vatOutput19    Float   @default(0)
  vatInput       Float   @default(0)
  vatLiability   Float   @default(0)
  euerRevenue    Float   @default(0)
  euerExpense    Float   @default(0)
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId, year, month])
  @@unique([companyId, year, month])
}

model Contact {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type          String
  name          String
  email         String?
  phone         String?
  vatId         String?
  street        String?
  postalCode    String?
  city          String?
  country       String?
  paymentTerms  Int      @default(14)
  notes         String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, type, active])
}

model DataExport {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  exportType   String
  status       String
  fileName     String
  periodLabel  String
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId, exportType, createdAt])
}
