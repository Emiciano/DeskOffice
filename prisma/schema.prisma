generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  users     User[]
  accounts  Account[]
  documents Document[]
  bookings  Booking[]
  invoices  Invoice[]
  offers    Offer[]
  bankTransactions BankTransaction[]
  autoRules Rule[]
  taxSnapshots TaxSnapshot[]
  contacts Contact[]
  exports DataExport[]
  settings  CompanySettings?
  products Product[]
  eInvoices EInvoiceDocument[]
  advisorInvites AdvisorInvite[]
  documentFiles DocumentFile[]
  members CompanyMember[]
  bankAccounts BankAccount[]
  costCenters CostCenter[]
  subscriptions Subscription[]
  auditLogs AuditLog[]
  roles Role[]
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String
  role         String        @default("owner")
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sessions     AuthSession[]
  memberships  CompanyMember[]
  auditLogs    AuditLog[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([companyId, role])
}

model Role {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code        String
  label       String
  permissions String   @db.LongText
  system      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members     CompanyMember[]

  @@unique([companyId, code])
  @@index([companyId])
}

model CompanyMember {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId      String?
  role        Role?    @relation(fields: [roleId], references: [id], onDelete: SetNull)
  status      String   @default("active")
  invitedBy   String?
  invitedAt   DateTime?
  joinedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([companyId, userId])
  @@index([companyId, status])
}

model AuthSession {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
}

model CompanySettings {
  id                     String   @id @default(cuid())
  companyId              String   @unique
  company                Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyName            String   @default("")
  companySuffix          String   @default("")
  legalForm              String   @default("")
  managingDirector       String   @default("")
  street                 String   @default("")
  postalCode             String   @default("")
  city                   String   @default("")
  country                String   @default("Deutschland")
  phone                  String   @default("")
  fax                    String   @default("")
  email                  String   @default("")
  website                String   @default("")
  vatId                  String   @default("")
  taxNumber              String   @default("")
  districtCourt          String   @default("")
  commercialRegisterNo   String   @default("")
  vatMode                String   @default("standard")
  profitMethod           String   @default("euer")
  defaultTaxRate         Float    @default(19)
  accountFrame           String   @default("SKR04")
  priceInputMode         String   @default("brutto")
  bankName               String   @default("")
  accountNumber          String   @default("")
  bankCode               String   @default("")
  iban                   String   @default("")
  bic                    String   @default("")
  logoUrl                String   @default("")
  invoicePrefix          String   @default("RE")
  invoiceNextNumber      Int      @default(101)
  offerPrefix            String   @default("AN")
  offerNextNumber        Int      @default(31)
  invoiceTemplate        String   @default("clean")
  updatedAt              DateTime @updatedAt
  createdAt              DateTime @default(now())
}

model Account {
  id        String   @id @default(cuid())
  number    String
  name      String
  type      String
  skrType   String
  taxRate   Float
  category  String
  active    Boolean  @default(true)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId, skrType])
  @@unique([companyId, number, skrType])
}

model Document {
  id           String    @id @default(cuid())
  fileName      String
  status        String
  accountNumber String?
  category      String?
  grossAmount   Float     @default(0)
  taxAmount     Float     @default(0)
  netAmount     Float     @default(0)
  partner       String?
  documentDate  DateTime?
  dueDate       DateTime?
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking       Booking?
  files         DocumentFile[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([companyId, status])
}

model DocumentFile {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  documentId   String
  document     Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  storageKey   String
  fileName     String
  mimeType     String
  sizeBytes    Int
  source       String   @default("upload")
  createdAt    DateTime @default(now())

  @@index([companyId, documentId])
}

model Booking {
  id            String   @id @default(cuid())
  documentId     String   @unique
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  debitAccount   String
  creditAccount  String
  amount         Float
  taxAmount      Float
  bookingText    String
  bookingDate    DateTime
  category       String
  costCenterId   String?
  costCenter     CostCenter? @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  status         String
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
}

model Invoice {
  id          String   @id @default(cuid())
  number      String
  customer    String
  amountNet   Float
  amountTax   Float
  amountGross Float
  dueDate     DateTime
  status      String
  sourceOfferId String?
  kind        String   @default("Rechnung")
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items       InvoiceItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  eInvoice    EInvoiceDocument?

  @@index([companyId, status])
  @@unique([companyId, number])
}

model Product {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name        String
  type        String
  unitPrice   Float
  taxRate     Float
  description String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, active])
}

model EInvoiceDocument {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceId    String   @unique
  invoice      Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  format       String
  status       String
  xmlPayload   String   @db.LongText
  validatedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId, format, status])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float
  amountNet   Float
  amountTax   Float
  amountGross Float
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Offer {
  id          String   @id @default(cuid())
  number      String
  customer    String
  amountNet   Float
  amountTax   Float
  amountGross Float
  validUntil  DateTime
  status      String
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, status])
  @@unique([companyId, number])
}

model BankTransaction {
  id          String   @id @default(cuid())
  bookingDate DateTime
  valueDate   DateTime?
  purpose     String
  counterparty String?
  amount      Float
  currency    String   @default("EUR")
  type        String
  status      String
  category    String?
  suggestedAccount String?
  matchedRuleId String?
  matchedInvoiceId String?
  matchedDocumentId String?
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, bookingDate])
}

model BankAccount {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name          String
  iban          String
  bic           String?
  bankName      String?
  currency      String   @default("EUR")
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  transactions  BankTransaction[]

  @@index([companyId, active])
}

model Rule {
  id          String   @id @default(cuid())
  name        String
  pattern     String
  accountNumber String?
  category    String?
  confidence  Float    @default(0.9)
  active      Boolean  @default(true)
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId, active])
}

model CostCenter {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code        String
  name        String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  bookings    Booking[]

  @@unique([companyId, code])
  @@index([companyId, active])
}

model TaxSnapshot {
  id            String   @id @default(cuid())
  periodLabel    String
  year           Int
  month          Int
  vatOutput19    Float   @default(0)
  vatInput       Float   @default(0)
  vatLiability   Float   @default(0)
  euerRevenue    Float   @default(0)
  euerExpense    Float   @default(0)
  companyId      String
  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId, year, month])
  @@unique([companyId, year, month])
}

model Contact {
  id            String   @id @default(cuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type          String
  name          String
  email         String?
  phone         String?
  vatId         String?
  street        String?
  postalCode    String?
  city          String?
  country       String?
  paymentTerms  Int      @default(14)
  notes         String?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([companyId, type, active])
}

model DataExport {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  exportType   String
  status       String
  fileName     String
  periodLabel  String
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([companyId, exportType, createdAt])
}

model Subscription {
  id                 String   @id @default(cuid())
  companyId          String
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  planCode           String
  status             String
  seats              Int      @default(1)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId, status])
}

model AuditLog {
  id         String   @id @default(cuid())
  companyId  String
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   String?  @db.LongText
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([companyId, entityType, createdAt])
}

model AdvisorInvite {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  email        String
  role         String   @default("tax_advisor")
  status       String   @default("pending")
  invitedBy    String
  invitedAt    DateTime @default(now())
  acceptedAt   DateTime?
  revokedAt    DateTime?

  @@index([companyId, status])
  @@unique([companyId, email, status])
}
