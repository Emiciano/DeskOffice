generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String          @id @default(cuid())
  email         String          @unique
  name          String?
  passwordHash  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  memberships   CompanyMember[]
  accounts      AuthAccount[]
  sessions      Session[]
  auditLogs     AuditLog[]
}

model Company {
  id            String          @id @default(cuid())
  name          String
  taxId         String?
  vatId         String?
  skrType       SkrType         @default(SKR03)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  members       CompanyMember[]
  accounts      ChartAccount[]
  documents     Document[]
  bookings      Booking[]
}

model CompanyMember {
  id            String          @id @default(cuid())
  userId        String
  companyId     String
  role          Role            @default(MITARBEITER)
  createdAt     DateTime        @default(now())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
}

model ChartAccount {
  id            String          @id @default(cuid())
  companyId      String
  number         String
  name           String
  type           AccountType
  skrType        SkrType
  taxRate        Float          @default(0)
  category       String
  description    String?
  active         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, skrType])
  @@unique([companyId, number, skrType])
}

model Document {
  id             String         @id @default(cuid())
  companyId      String
  fileName       String
  mimeType       String
  fileUrl        String
  status         DocumentStatus @default(ENTWURF)
  type           DocumentType   @default(SONSTIGER_BELEG)
  invoiceNumber  String?
  documentDate   DateTime?
  dueDate        DateTime?
  partnerName    String?
  netAmount      Float          @default(0)
  vatAmount      Float          @default(0)
  grossAmount    Float          @default(0)
  currency       String         @default("EUR")
  category       String?
  accountNumber  String?
  costCenter     String?
  notes          String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  booking        Booking?
}

model Booking {
  id             String         @id @default(cuid())
  companyId      String
  documentId     String         @unique
  debitAccount   String
  creditAccount  String
  amount         Float
  taxAmount      Float
  bookingText    String
  bookingDate    DateTime
  status         BookingStatus  @default(GEBUCHT)
  createdAt      DateTime       @default(now())
  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  document       Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id             String         @id @default(cuid())
  userId         String?
  companyId      String?
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  createdAt      DateTime       @default(now())
  user           User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// Auth.js tables
model AuthAccount {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

enum Role {
  OWNER
  ADMIN
  MITARBEITER
  STEUERBERATER
}

enum SkrType {
  SKR03
  SKR04
}

enum AccountType {
  ASSET
  EXPENSE
  REVENUE
  LIABILITY
  TAX
  BANK
  CASH
}

enum DocumentStatus {
  ENTWURF
  GEPRUEFT
  GEBUCHT
  BEZAHLT
  UEBERFAELLIG
}

enum DocumentType {
  EINGANGSRECHNUNG
  AUSGANGSRECHNUNG
  QUITTUNG
  GUTSCHRIFT
  SONSTIGER_BELEG
}

enum BookingStatus {
  GEBUCHT
  STORNIERT
}
